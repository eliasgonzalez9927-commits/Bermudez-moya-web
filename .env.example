# ── Resend (emails transaccionales) ──────────────────────────────────────────
# 1. Crear cuenta en https://resend.com (gratis hasta 3.000 emails/mes)
# 2. Ir a "API Keys" → crear clave → copiar abajo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email desde el que se envían los correos
# En desarrollo: usa "onboarding@resend.dev" (solo envía al email del dueño de la cuenta)
# En producción: usa un dominio verificado (ej: noreply@bermudezmoya.com)
FROM_EMAIL=onboarding@resend.dev

# Email donde llegan las notificaciones de nuevos leads
CONTACT_EMAIL=bermudezmoyap@gmail.com

# ── Gvamax CRM ────────────────────────────────────────────────────────────────
VITE_GVAMAX_ID=1253
VITE_GVAMAX_TOKEN=b495ce63ede0f4efc9eec62cb947c162

# ── DNS para verificar dominio en Resend (producción) ─────────────────────────
# Agregar estos registros en el panel DNS de tu dominio (ej: Cloudflare, GoDaddy):
#
# Tipo   Nombre                        Valor
# ─────────────────────────────────────────────────────────────────────────────
# TXT    resend._domainkey.TUDOMINIO   → lo genera Resend al agregar el dominio
# MX     send.TUDOMINIO                → feedback-smtp.us-east-1.amazonses.com
# TXT    send.TUDOMINIO                → "v=spf1 include:amazonses.com ~all"
#
# Pasos:
# 1. En Resend: Settings → Domains → Add Domain → ingresar tu dominio
# 2. Resend te muestra los registros DNS exactos a configurar
# 3. Una vez propagados (5-30 min), el dominio aparece como "Verified"
# 4. Cambiar FROM_EMAIL a noreply@tudominio.com
